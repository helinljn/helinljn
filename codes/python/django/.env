# =============================================================================
# Django 核心配置
# =============================================================================

# 控制 Django 是否启用调试模式。开发环境通常为 True，生产环境必须为 False。
DJANGO_DEBUG=True

# Django 的核心密钥，用于 Session、CSRF、签名等安全场景。生产环境必须使用高强度随机值。
DJANGO_SECRET_KEY=0fv-m7ba&J3HCU_=-RhGX=4p7XZgGHVUSYT*DJ0T57@4h_GP%a

# 限制允许访问当前 Django 站点的 Host。多个值用英文逗号分隔。
# 开发环境示例：127.0.0.1,localhost
# 生产环境示例：gm.example.com,admin.example.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost


# =============================================================================
# 数据库
# =============================================================================

# SQLite 配置。仅当 DB_ENGINE=sqlite 时生效。
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_SQLITE_TIMEOUT=20

# MySQL 配置。仅当 DB_ENGINE=mysql 时生效。
# DB_ENGINE=mysql
# DB_NAME=gmtool
# DB_USER=gmtool
# DB_PASSWORD=111111
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_CONN_MAX_AGE=600


# =============================================================================
# IDIP / 命令定义
# =============================================================================

# GM 命令转发的目标 IDIP 接口地址。开发联调时可指向本地 mock 服务。
IDIP_API_URL=http://127.0.0.1:18080/cy_idip

# 调用 IDIP 接口时的请求超时时间，单位为秒。
IDIP_TIMEOUT=30

# 命令定义文件 idip_commands.json 的路径，供命令同步、上传、文件监控使用。
IDIP_JSON_PATH=idip_commands.json

# 上传命令定义 JSON 文件时允许的最大字节数。当前 10485760 = 10MB。
UPLOAD_MAX_SIZE=10485760


# =============================================================================
# 命令执行 / 展示
# =============================================================================

# 前端批量执行 GM 命令时，单次允许处理的最大目标数量。
BATCH_EXECUTE_MAX_TARGETS=100

# 前端批量执行 GM 命令时，两次请求之间的间隔，单位为毫秒。
BATCH_EXECUTE_INTERVAL_MS=100

# 后台列表页（如日志、用户列表）默认每页显示的条数。
PAGE_SIZE=20


# =============================================================================
# 文件监控（开发便利功能）
# =============================================================================

# 是否启用对 idip_commands.json 的自动变更监控中间件。
# 建议：
# - 开发环境可设为 True，减少手工同步操作
# - 生产环境建议设为 False，并通过 `python manage.py sync_commands`
#   或上传 JSON 后自动同步，不建议依赖请求中间件作为主同步机制
ENABLE_IDIP_FILE_MONITOR=False

# 文件监控检查间隔，单位为秒，用于降低每个请求都检查文件的开销。
IDIP_FILE_CHECK_INTERVAL=30

# 文件监控时是否使用哈希比对而不是修改时间比对。更准确，但性能开销更高。
IDIP_USE_HASH_CHECK=False


# =============================================================================
# 登录安全
# =============================================================================

# 登录限速允许的最大失败次数。超过后会触发临时锁定。
LOGIN_MAX_ATTEMPTS=5

# 登录失败达到阈值后，锁定时长，单位为秒。
LOGIN_LOCKOUT_SECONDS=300


# =============================================================================
# 日志脱敏
# =============================================================================

# 日志详情接口和日志脱敏逻辑使用的敏感字段名列表，多个值用英文逗号分隔。
SENSITIVE_FIELDS=password,passwd,pwd,token,access_token,refresh_token,secret,sign,signature,sessionid,cookie,authorization


# =============================================================================
# 反向代理
# =============================================================================

# 是否信任反向代理传入的 X-Forwarded-For，用于获取真实客户端 IP。
# 仅在你确认请求一定经过可信代理（如 Nginx）时才建议设为 True。
DJANGO_TRUSTED_PROXY=False

# 可信代理层数。解析 X-Forwarded-For 时，会从右向左跳过这么多个代理 IP。
DJANGO_TRUSTED_PROXY_COUNT=1


# =============================================================================
# 会话 / Cookie
# =============================================================================

# 控制浏览器是否只通过 HTTPS 发送 Session Cookie。
# 若系统部署在 Nginx / SLB / Ingress 等 HTTPS 反向代理之后，生产环境通常应设为 True。
SESSION_COOKIE_SECURE=False

# 控制浏览器是否只通过 HTTPS 发送 CSRF Cookie。
# 若系统部署在 Nginx / SLB / Ingress 等 HTTPS 反向代理之后，生产环境通常应设为 True。
CSRF_COOKIE_SECURE=False
