{
    "C_Cpp.intelliSenseCacheSize": 0,
    "C_Cpp.intelliSenseCachePath": "${workspaceFolder}/.build/cache",
    "C_Cpp.default.browse.databaseFilename": "${workspaceFolder}/.build/cache/browse.vc.db",
    "C_Cpp.files.exclude": {
        "**/.vs": true,
        "**/.vscode": true,
        "**/.build": true,
        "**/samples": true,
        "**/fuzzing": true,
        "**/testsuite": true
    },

    "search.exclude": {
        "**/samples": true,
        "**/fuzzing": true,
        "**/testsuite": true
    },

    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.vs": true,
        "**/.vscode": true,
        "**/.build": true
    },

    "files.associations": {
        "*.c": "c",
        "*.cc": "cpp",
        "*.cpp": "cpp",
        "*.tcc": "cpp"
    }
}
